# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Async Postgres connection string used by SQLAlchemy.
# Local dev default: postgresql+asyncpg://dan:social123@localhost:5432/social
# Railway/production: provided by the platform as DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Secret used to sign JWT access tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-long-random-string

# Set to "1" to skip running Base.metadata.create_all() at startup.
# Useful in tests or when migrations are managed separately.
SKIP_DB_INIT=
